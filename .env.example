# Copy this file to `.env` in the repo root and fill in your own keys.
# `.env` is gitignored — never commit it.

# OpenAI API key — required for /banner2 (gpt-image-1-mini default, gpt-image-2 with --max).
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Figma personal access token — required for the Framelink MCP (figma-developer-mcp).
# Get yours at: https://www.figma.com/settings (Personal access tokens)
# Required scopes: file_content:read, file_metadata:read (read-only is enough for Framelink).
# Also used by /qa and /translate-figma for direct Figma REST access.
FIGMA_API_KEY=figd_...
