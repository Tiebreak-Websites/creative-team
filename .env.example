# Copy this file to `.env` (gitignored) and fill in your keys.

# OpenAI — required for the Banner Builder (gpt-image-2 / gpt-image-1-mini).
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Figma personal access token — required for Figma QA, Creative Summary, and Translate
# (file read; add comments:write to let QA post findings as comments).
# https://www.figma.com/settings  →  Personal access tokens
FIGMA_API_KEY=figd_...

# Anthropic — required for the AI features: Creative Summary, Translate, the Banner Builder
# "Generate with AI" brief, and QA's AI tone check.
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...
