# Production env for a Cloudflare Tunnel deploy of the Creative Tools platform.
#
# Two ways to apply these (process env wins over any file — see settings.py):
#   1. Copy the values you need into the repo-root .env (gitignored), OR
#   2. Set them as real environment variables for the backend process / service.
#
# NEVER commit real secret values. This file holds placeholders only.

# --- Network -------------------------------------------------------------
# Bind to loopback only: cloudflared connects locally, nothing else should.
PLATFORM_HOST=127.0.0.1
PLATFORM_PORT=8000

# Single-origin deploy: the SPA is same-origin with the API, so no browser CORS
# is needed. Keep `null` so the Figma plugin's sandboxed iframe (Origin: null)
# can still reach /api/plugin/* if you use the plugin bridge.
PLATFORM_CORS_ORIGINS=null

# The site is HTTPS behind the tunnel, so the session cookie must be Secure.
PLATFORM_COOKIE_SECURE=true

# Public site with no Zero Trust gate: hide the interactive API docs so an
# anonymous visitor only ever sees the login page.
PLATFORM_DOCS=false

# --- Auth / sessions -----------------------------------------------------
# Pin a stable signing key so sessions survive a backend restart. Generate one:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
PLATFORM_SECRET_KEY=replace-with-a-long-random-string

# The seeded admin. Prefer a PRE-HASHED password over plaintext for a shared
# deploy. Generate the hash (matches auth.py's bcrypt scheme):
#   python -c "from passlib.context import CryptContext; print(CryptContext(schemes=['bcrypt']).hash('YOUR-PASSWORD'))"
ADMIN_EMAIL=you@your-domain.com
ADMIN_PASSWORD_HASH=$2b$12$replace-with-a-real-bcrypt-hash

# --- Provider keys -------------------------------------------------------
# Banner Builder image generation (required for that tool):
OPENAI_API_KEY=sk-...
# AI-assist brief + Creative Summary (optional):
ANTHROPIC_API_KEY=sk-ant-...
# Figma QA / Translate tools (optional):
FIGMA_API_KEY=figd_...
